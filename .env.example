# ===== Database =====
DATABASE_URL=postgresql://pm:pm@localhost:5432/pmagnt
# TimescaleDB works on standard PostgreSQL wire protocol.

# ===== Polymarket (Gamma / Data / CLOB) =====
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriber-clob.polymarket.com/ws
# CLOB auth (Phase B, not needed for read-only Gamma/Data):
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CHAIN_ID=137

# Gamma rate limits (secondary source — verify against official docs).
# Configurable token bucket; do not hardcode as truth.
POLYMARKET_GAMMA_RPS=20
POLYMARKET_DATA_RPS=10
POLYMARKET_CLOB_RPS=40

# ===== Kalshi =====
KALSHI_REST_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2
# Kalshi RSA keypair (Phase B for orders; read-only markets work without):
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_RPS=5

# ===== Collection =====
# Watchlist tiers (seconds between snapshots)
SNAPSHOT_ARB_SEC=5
SNAPSHOT_LIQUID_SEC=15
SNAPSHOT_PRERES_SEC=30
SNAPSHOT_NARRATIVE_SEC=900
UNIVERSE_DISCOVERY_SEC=600
RULES_REFRESH_SEC=3600

# ===== Logging =====
LOG_LEVEL=INFO
LOG_JSON=true
